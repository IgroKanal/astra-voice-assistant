# =========================
# ASSISTANT SETTINGS
# =========================
ASSISTANT_NAME=Астра
WAKE_PHRASES=астра,эй астра,привет астра,астро,остра,а стра

# true  - можно выполнять явные команды без имени ассистента
# false - сначала нужно сказать wake phrase
ALLOW_COMMANDS_WITHOUT_WAKE=true

# =========================
# LLM SETTINGS
# =========================
LLM_ENABLED=true
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Основная Gemini-модель. Если она недоступна, используется GEMINI_FALLBACK_MODEL.
GEMINI_MODEL=gemma-4-26b-a4b-it
GEMINI_FALLBACK_MODEL=gemini-3.5-flash

# Legacy-настройки для OpenAI-compatible провайдеров не-Gemini.
# Для Gemini эти строки ниже используются только если GEMINI_MODEL не задан.
LLM_MODEL=gemini-3.5-flash
LLM_FALLBACK_MODEL=

LLM_SYSTEM_PROMPT=Ты голосовой ассистент для ПК. Твоё имя Астра. Отвечай кратко, понятно и по делу. Обычно 1–3 предложения. Не показывай черновики, Draft, варианты ответа и внутренние рассуждения.
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500
LLM_TIMEOUT_SECONDS=30

# Gemini command router:
# true  - Gemini помогает понять криво распознанные команды
# false - используется только локальный парсер
LLM_ROUTER_ENABLED=true
LLM_ROUTER_MIN_CONFIDENCE=0.55

# =========================
# SPEECH SETTINGS
# =========================
SPEECH_LANGUAGE=ru-RU
LISTEN_TIMEOUT_SECONDS=8
PHRASE_TIME_LIMIT_SECONDS=12
AMBIENT_NOISE_DURATION_SECONDS=1.0

# Тонкая настройка SpeechRecognition
STT_DYNAMIC_ENERGY_THRESHOLD=true
STT_ENERGY_THRESHOLD=0
STT_PAUSE_THRESHOLD=0.9
STT_NON_SPEAKING_DURATION=0.5
STT_SHOW_ALTERNATIVES=true
STT_PREFER_CYRILLIC=true

# =========================
# TTS SETTINGS
# =========================
TTS_ENABLED=true

# edge = Microsoft Edge online neural voices
# sapi = pyttsx3 / Windows SAPI5 fallback
TTS_ENGINE=edge

TTS_EDGE_VOICE=ru-RU-DmitryNeural
TTS_EDGE_RATE=+10%
TTS_EDGE_VOLUME=+0%
TTS_EDGE_PITCH=+0Hz

# Старые SAPI-настройки можно оставить как fallback
TTS_RATE=180
TTS_VOLUME=1.0
TTS_VOICE_NAME=
TTS_DEBUG_VOICES=true
