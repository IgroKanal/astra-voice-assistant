# =========================
# ASSISTANT SETTINGS
# =========================
ASSISTANT_NAME=Астра
WAKE_PHRASES=астра,эй астра,привет астра,астро,остра,а стра,астер,астэр,астры

ALLOW_COMMANDS_WITHOUT_WAKE=false
ALLOW_TEXT_CONVERSATION_WITHOUT_WAKE=true
ALLOW_VOICE_CONVERSATION_WITHOUT_WAKE=false
ROUTER_COOLDOWN_SECONDS=2.0

# =========================
# V0.11 WAKE-ONLY VOICE RUNTIME
# =========================
# wake_only = голосовой режим ждёт слово "Астра" и не обрабатывает обычную речь.
# legacy    = старый dev-режим постоянного распознавания.
VOICE_RUNTIME_MODE=wake_only
WAKE_ONLY_MODE=true
WAKE_RESPONSE_ENABLED=true
WAKE_RESPONSE_TEXT=Слушаю.
WAKE_LISTEN_TIMEOUT_SECONDS=4
WAKE_PHRASE_TIME_LIMIT_SECONDS=4
COMMAND_LISTEN_TIMEOUT_SECONDS=10
COMMAND_PHRASE_TIME_LIMIT_SECONDS=16
# true  = "Астра, команда" выполняется сразу.
# false = "Астра, команда" только открывает command session.
WAKE_ALLOW_DIRECT_COMMAND=true

# =========================
# LLM / GEMINI SETTINGS
# =========================
LLM_ENABLED=true
LLM_PROVIDER=gemini

GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemma-4-31b-it
GEMINI_FALLBACK_MODEL=gemini-3.5-flash

LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

LLM_SYSTEM_PROMPT=Ты голосовой ассистент для ПК. Твоё имя Астра. Отвечай кратко, понятно и законченными фразами. Обычно 1–3 предложения. Не используй markdown и черновики.

LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=500
LLM_TIMEOUT_SECONDS=30

LLM_ROUTER_ENABLED=true
LLM_ROUTER_MIN_CONFIDENCE=0.55

# =========================
# SPEECH / STT SETTINGS
# =========================
SPEECH_LANGUAGE=ru-RU
LISTEN_TIMEOUT_SECONDS=10
PHRASE_TIME_LIMIT_SECONDS=16
AMBIENT_NOISE_DURATION_SECONDS=0.6

STT_DYNAMIC_ENERGY_THRESHOLD=true
STT_ENERGY_THRESHOLD=0
STT_PAUSE_THRESHOLD=1.15
STT_NON_SPEAKING_DURATION=0.8
STT_SHOW_ALTERNATIVES=true
STT_PREFER_CYRILLIC=true

# =========================
# TTS SETTINGS
# =========================
TTS_ENABLED=true
TTS_ENGINE=edge

TTS_EDGE_VOICE=ru-RU-SvetlanaNeural
TTS_EDGE_FALLBACK_VOICE=ru-RU-DmitryNeural
TTS_EDGE_RATE=+10%
TTS_EDGE_VOLUME=+0%
TTS_EDGE_PITCH=+0Hz

TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=
TTS_CACHE_PREWARM_ENABLED=true
TTS_CACHE_PREWARM_MAX_NEW_PHRASES=1
TTS_CACHE_GENERATION_TIMEOUT_SECONDS=8
TTS_CACHE_PREWARM_PHRASES=Астра запущена.,Слушаю.,Открываю.,Открываю сайт.,Закрываю.,Ищу.,Завершаю работу.,Не расслышал повтори.,Что открыть?,Что закрыть?,Готово.,Пишу.,Закрываю вкладку.,Открываю новую вкладку.,Открываю новое окно.,Обновляю.,Открываю папку.,Скриншот сохранён.,Громче.,Тише.,Переключаю звук.,VPN включён.,VPN выключен.,Открытие окна отключено.,Закрытие окна отключено.,Смешанные команды отключены.,Какой чат открыть: ChatGPT или Telegram?,Показываю рабочий стол.,Сворачиваю окно.,Разворачиваю окно.,Пока нечего повторять.,Интернет доступен.,Открываю загрузки.,Открываю историю.,На какое окно переключиться?,Открываю буфер обмена.
TTS_LOG_TIMING=true

# SAPI fallback settings
TTS_RATE=180
TTS_VOLUME=1.0
TTS_VOICE_NAME=
TTS_DEBUG_VOICES=true

# =========================
# V0.9 VOICE RELIABILITY SETTINGS
# =========================
STT_COMMAND_AWARE_ALTERNATIVES=true
STT_MISTAKE_LOG_ENABLED=true
STT_MISTAKE_LOG_PATH=logs/stt_mistakes.log

# User currently tests mostly in Firefox. Set msedge/chrome/firefox if needed.
BROWSER_PREFERRED=firefox
BROWSER_FOCUS_MISSING_TIMEOUT_SECONDS=0.35

# Optional override for a non-standard native Yandex Music installation.
# Leave empty for automatic LOCALAPPDATA/StartApps resolution.
ASTRA_YANDEX_MUSIC_PATH=

ROUTINES_ENABLED=true
ROUTINES_CONFIG_PATH=config/routines.json
CONTEXT_TTL_SECONDS=120

VOICE_SHORT_RESPONSES=true
VOICE_MAX_SPEAK_CHARS=180

# =========================
# V0.10 VPN CONTROL SETTINGS
# =========================
VPN_ENABLED=true
VPN_PROVIDER=amneziawg
VPN_TUNNEL_SERVICE_NAME=AmneziaWGTunnel$pc-awg-2
VPN_MANAGER_SERVICE_NAME=AmneziaWGManager
VPN_COMMAND_TIMEOUT_SECONDS=15
