# =========================
# ASSISTANT SETTINGS
# =========================
ASSISTANT_NAME=Астра
WAKE_PHRASES=астра,эй астра,привет астра

# Режим LLM:
# true  - обычные вопросы отправляются в LLM
# false - ассистент работает только с локальными командами
LLM_ENABLED=true

# =========================
# LLM SETTINGS
# =========================
# Стартовый бесплатный вариант: gemini
# Возможные значения: gemini, openai, ollama
LLM_PROVIDER=gemini

# API-ключ провайдера.
# Для Gemini ключ берётся в Google AI Studio.
# Для Ollama можно оставить ollama.
LLM_API_KEY=your_gemini_api_key_here

# Gemini OpenAI-compatible endpoint
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Модель по умолчанию для Gemini OpenAI-compatible endpoint
LLM_MODEL=gemini-3.5-flash

# Системный промпт
LLM_SYSTEM_PROMPT=Ты голосовой ассистент для ПК. Твоё имя Астра. Отвечай кратко, понятно и по делу. Обычно 1–3 предложения.

# Ограничения ответа
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=300
LLM_TIMEOUT_SECONDS=30

# =========================
# SPEECH SETTINGS
# =========================
SPEECH_LANGUAGE=ru-RU
LISTEN_TIMEOUT_SECONDS=5
PHRASE_TIME_LIMIT_SECONDS=8
AMBIENT_NOISE_DURATION_SECONDS=0.5

# =========================
# TTS SETTINGS
# =========================
TTS_ENABLED=true
TTS_RATE=180
TTS_VOLUME=1.0
