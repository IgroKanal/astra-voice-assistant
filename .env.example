# =========================
# ASSISTANT SETTINGS
# =========================
ASSISTANT_NAME=Астра
WAKE_PHRASES=астра,эй астра,привет астра,астро,остра,а стра

ALLOW_COMMANDS_WITHOUT_WAKE=true
ALLOW_TEXT_CONVERSATION_WITHOUT_WAKE=true
ALLOW_VOICE_CONVERSATION_WITHOUT_WAKE=false
ROUTER_COOLDOWN_SECONDS=2.0

# =========================
# LLM / GEMINI SETTINGS
# =========================
LLM_ENABLED=true
LLM_PROVIDER=gemini

GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemma-4-31b-it
GEMINI_FALLBACK_MODEL=gemini-3.5-flash

LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

LLM_SYSTEM_PROMPT=Ты голосовой ассистент для ПК. Твоё имя Астра. Отвечай кратко, понятно и законченными фразами. Обычно 1–3 предложения. Не используй markdown и черновики.

LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=500
LLM_TIMEOUT_SECONDS=30

LLM_ROUTER_ENABLED=true
LLM_ROUTER_MIN_CONFIDENCE=0.55

# =========================
# SPEECH / STT SETTINGS
# =========================
SPEECH_LANGUAGE=ru-RU
LISTEN_TIMEOUT_SECONDS=8
PHRASE_TIME_LIMIT_SECONDS=12
AMBIENT_NOISE_DURATION_SECONDS=1.0

STT_DYNAMIC_ENERGY_THRESHOLD=true
STT_ENERGY_THRESHOLD=0
STT_PAUSE_THRESHOLD=0.9
STT_NON_SPEAKING_DURATION=0.5
STT_SHOW_ALTERNATIVES=true
STT_PREFER_CYRILLIC=true

# =========================
# TTS SETTINGS
# =========================
TTS_ENABLED=true
TTS_ENGINE=edge

TTS_EDGE_VOICE=ru-RU-SvetlanaNeural
TTS_EDGE_FALLBACK_VOICE=ru-RU-DmitryNeural
TTS_EDGE_RATE=+10%
TTS_EDGE_VOLUME=+0%
TTS_EDGE_PITCH=+0Hz

TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=
TTS_CACHE_PREWARM_ENABLED=true
TTS_CACHE_PREWARM_PHRASES=Астра запущена.,Слушаю.,Открываю.,Открываю сайт.,Закрываю.,Ищу.,Завершаю работу.,Не расслышал повтори.,Что открыть?,Что закрыть?,Готово.,Пишу.,Закрываю вкладку.,Открываю новую вкладку.,Обновляю.,Открываю папку.,Скриншот сохранён.,Громче.,Тише.,Переключаю звук.
TTS_LOG_TIMING=true

# SAPI fallback settings
TTS_RATE=180
TTS_VOLUME=1.0
TTS_VOICE_NAME=
TTS_DEBUG_VOICES=true

# =========================
# V0.9 VOICE RELIABILITY SETTINGS
# =========================
STT_COMMAND_AWARE_ALTERNATIVES=true
STT_MISTAKE_LOG_ENABLED=true
STT_MISTAKE_LOG_PATH=logs/stt_mistakes.log

# User currently tests mostly in Firefox. Set msedge/chrome/firefox if needed.
BROWSER_PREFERRED=firefox
BROWSER_FOCUS_MISSING_TIMEOUT_SECONDS=0.35

VOICE_SHORT_RESPONSES=true
VOICE_MAX_SPEAK_CHARS=180

# =========================
# V0.10 VPN CONTROL SETTINGS
# =========================
VPN_ENABLED=true
VPN_PROVIDER=amneziawg
VPN_TUNNEL_SERVICE_NAME=AmneziaWGTunnel$pc-awg-2
VPN_MANAGER_SERVICE_NAME=AmneziaWGManager
VPN_COMMAND_TIMEOUT_SECONDS=15

